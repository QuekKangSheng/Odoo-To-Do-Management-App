<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View with color-coded rows and badge -->
    <record id="view_todo_list_tree" model="ir.ui.view">
        <field name="name">todo.list.tree</field>
        <field name="model">todo.list</field>
        <field name="arch" type="xml">
            <tree decoration-success="status == 'complete'"
                  decoration-warning="status == 'in_progress'"
                  decoration-muted="status == 'draft'">
                <field name="name"/>
                <field name="tag_ids" widget="many2many_tags"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="items_progress"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'complete'"
                       decoration-warning="status == 'in_progress'"
                       decoration-danger="status == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_todo_list_form" model="ir.ui.view">
        <field name="name">todo.list.form</field>
        <field name="model">todo.list</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start"
                            string="Start"
                            type="object"
                            class="btn-primary"
                            invisible="status != 'draft'"/>
                    <button name="action_complete"
                            string="Mark as Complete"
                            type="object"
                            class="btn-success"
                            invisible="status != 'in_progress' or not all_items_done"/>
                    <field name="status"
                           widget="statusbar"
                           statusbar_visible="draft,in_progress,complete"/>
                </header>
                <sheet>
                    <field name="all_items_done" invisible="1"/>

                    <!-- Progress banner -->
                    <div class="alert alert-info d-flex align-items-center mb-3"
                         invisible="status == 'draft'">
                        <strong>Progress: </strong>
                        <field name="items_progress"
                               readonly="1"
                               nolabel="1"
                               class="ms-2"/>
                    </div>

                    <group>
                        <group string="General Info">
                            <field name="name"
                                   readonly="status == 'complete'"/>
                            <field name="tag_ids"
                                   widget="many2many_tags"
                                   readonly="status == 'complete'"/>
                        </group>
                        <group string="Dates">
                            <field name="start_date"
                                   readonly="status == 'complete'"/>
                            <field name="end_date"
                                   readonly="status == 'complete'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Todo Items">
                            <field name="item_ids"
                                   readonly="status == 'complete'">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="is_finished"
                                           column_invisible="parent.status != 'in_progress'"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Attendees">
                            <field name="attendee_ids"
                                   readonly="status == 'complete'">
                                <tree editable="bottom">
                                    <field name="user_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_todo_list_search" model="ir.ui.view">
        <field name="name">todo.list.search</field>
        <field name="model">todo.list</field>
        <field name="arch" type="xml">
            <search string="Search Todo Lists">

                <!-- Search by title and tags -->
                <field name="name" string="Title"/>
                <field name="tag_ids" string="Tags"/>

                <!-- Two filters only -->
                <filter string="Uncomplete"
                        name="filter_uncomplete"
                        domain="[('status', 'in', ['draft', 'in_progress'])]"/>
                <filter string="Complete"
                        name="filter_complete"
                        domain="[('status', '=', 'complete')]"/>

                <separator/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter string="Status"
                            name="group_by_status"
                            context="{'group_by': 'status'}"/>
                    <filter string="Tags"
                            name="group_by_tags"
                            context="{'group_by': 'tag_ids'}"/>
                </group>

            </search>
        </field>
    </record>

    <!-- Single action — all records -->
    <record id="action_todo_list_all" model="ir.actions.act_window">
        <field name="name">Todo List</field>
        <field name="res_model">todo.list</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_todo_list_search"/>
    </record>

</odoo>